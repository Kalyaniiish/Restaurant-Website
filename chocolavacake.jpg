<div id="mm-recipes-review-bar_1-0" class="comp mm-recipes-review-bar mntl-block has-ratings has-comments js-recipe-review-bar"><div id="mm-recipes-review-bar__star-rating_1-0" class="comp mm-recipes-review-bar__star-rating mntl-recipe-star-rating mm-recipes-star-rating" data-click-tracked="true" data-tracking-subtype="Top Nav - Jump to Reviews - Rating" data-track-rating-location="Top Nav - Jump to Reviews - Stars" data-tracking-subcategory="Review Bar" data-tracking-container="true" data-tracking-category="User Recipe Action">
