<div id="article-content_1-0" class="comp article-content mntl-block"><div id="mm-recipes-details_1-0" class="comp mm-recipes-details recipe-details"> <div class="mm-recipes-details__content">
<div class="mm-recipes-details__item">
<div class="mm-recipes-details__label">Active Time:</div>
<div class="mm-recipes-details__value">20 mins</div>
</div>
<div class="mm-recipes-details__item">
